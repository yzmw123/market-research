<!doctype html>
<html lang="zh-CN" data-theme="{{ theme }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    :root {
      color-scheme: light;
      --page: #f3f1ec;
      --surface: #fffefb;
      --surface-muted: #f7f3eb;
      --text: #1b1d20;
      --muted: #666b73;
      --line: #d9d2c5;
      --accent: #a8563d;
      --accent-soft: #f4e2d8;
      --link: #185ea8;
      --shadow: 0 12px 34px rgba(51, 45, 36, .08);
    }
    html[data-theme="dark"] {
      color-scheme: dark;
      --page: #0e1116;
      --surface: #171b22;
      --surface-muted: #202631;
      --text: #edf0f5;
      --muted: #a7afbb;
      --line: #343c49;
      --accent: #ff9c73;
      --accent-soft: #38251f;
      --link: #74b9ff;
      --shadow: 0 12px 34px rgba(0, 0, 0, .28);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--page);
      color: var(--text);
      font: 15px/1.75 -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
      overflow-wrap: anywhere;
    }
    a { color: var(--link); }
    .layout {
      display: grid;
      grid-template-columns: 260px minmax(0, 1fr);
      gap: 28px;
      width: min(1420px, 100%);
      margin: 0 auto;
      padding: 24px;
    }
    .sidebar {
      position: sticky;
      top: 24px;
      align-self: start;
      max-height: calc(100vh - 48px);
      overflow-y: auto;
      padding: 22px 18px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--surface);
      box-shadow: var(--shadow);
    }
    .toc-label { margin: 0 0 12px; color: var(--accent); font-size: 12px; font-weight: 700; letter-spacing: .12em; }
    .toc-link { display: block; padding: 6px 8px; border-radius: 7px; color: var(--muted); text-decoration: none; font-size: 13px; }
    .toc-link:hover { color: var(--text); background: var(--surface-muted); }
    .toc-level-3 { padding-left: 20px; font-size: 12px; }
    .main { min-width: 0; }
    .hero, .report-content {
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--surface);
      box-shadow: var(--shadow);
    }
    .hero { padding: clamp(26px, 5vw, 52px); margin-bottom: 20px; }
    .hero-kicker { margin: 0 0 10px; color: var(--accent); font-size: 12px; font-weight: 700; letter-spacing: .12em; }
    .hero h1 { margin: 0; font-size: clamp(28px, 4vw, 46px); line-height: 1.2; letter-spacing: -.025em; }
    .hero-meta { margin-top: 16px; color: var(--muted); font-size: 13px; }
    .report-content { padding: clamp(22px, 4vw, 48px); }
    h2 { margin: 46px 0 16px; padding-top: 16px; border-top: 1px solid var(--line); font-size: 24px; line-height: 1.35; }
    h2:first-child { margin-top: 0; padding-top: 0; border-top: 0; }
    h3 { margin: 30px 0 12px; color: var(--accent); font-size: 18px; line-height: 1.4; }
    p, ul, ol, blockquote { margin: 10px 0; }
    li + li { margin-top: 5px; }
    blockquote { padding: 2px 16px; border-left: 3px solid var(--accent); color: var(--muted); background: var(--surface-muted); }
    code { padding: 2px 5px; border-radius: 5px; background: var(--surface-muted); }
    pre { overflow-x: auto; padding: 16px; border: 1px solid var(--line); border-radius: 10px; background: var(--surface-muted); }
    pre code { padding: 0; background: transparent; }
    strong { padding: 1px 4px; border-radius: 4px; background: var(--accent-soft); }
    .table-wrap { width: 100%; margin: 18px 0; overflow-x: auto; border: 1px solid var(--line); border-radius: 10px; }
    table { width: 100%; min-width: 640px; border-collapse: collapse; font-size: 13px; }
    th, td { padding: 10px 12px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); text-align: left; vertical-align: top; }
    th { background: var(--surface-muted); white-space: nowrap; }
    tr:last-child td { border-bottom: 0; }
    th:last-child, td:last-child { border-right: 0; }
    tr:target td { background: var(--accent-soft); }
    .source-ref { padding: 0 3px; border-radius: 4px; color: var(--accent); font-size: .82em; font-weight: 700; text-decoration: none; }
    .source-ref:hover, .source-ref:focus { background: var(--accent-soft); }
    .source-back { color: var(--muted); text-decoration: none; }
    .footer { padding: 20px 4px 4px; color: var(--muted); text-align: right; font-size: 12px; }
    @media (max-width: 840px) {
      .layout { display: block; padding: 12px; }
      .sidebar { position: relative; top: 0; max-height: none; margin-bottom: 14px; }
      .main { width: 100%; }
      .hero { padding: 26px 22px; }
      .report-content { padding: 22px 18px; }
      h2 { font-size: 21px; }
      table { min-width: 560px; }
    }
    @media print {
      body { background: #fff; color: #000; }
      .layout { display: block; width: 100%; padding: 0; }
      .sidebar { display: none; }
      .hero, .report-content { border: 0; box-shadow: none; }
      a { color: inherit; text-decoration: none; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar" aria-label="报告目录">
      <p class="toc-label">目录</p>
      {% for item in toc %}
      <a class="toc-link toc-level-{{ item.level }}" href="#{{ item.id }}">{{ item.title }}</a>
      {% endfor %}
    </aside>
    <main class="main">
      <header class="hero">
        <p class="hero-kicker">MARKET RESEARCH</p>
        <h1>{{ title }}</h1>
        <p class="hero-meta">报告生成日期：{{ generated_at }}</p>
      </header>
      <article class="report-content">{{ body_html | safe }}</article>
      <footer class="footer">公开证据决策报告 · {{ generated_at }}</footer>
    </main>
  </div>
</body>
</html>
